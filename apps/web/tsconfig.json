{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@viewpulse/configs": ["../../packages/configs/index.ts"],
      "@viewpulse/schemas": ["../../packages/schemas/index.ts"],
      "@viewpulse/utils/*": ["../../packages/utils/*"],
      "@viewpulse/components/*": ["../../packages/components/*"],
      "@viewpulse/ai/*": ["../../packages/ai/*"]
    },
    "baseUrl": "."
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
